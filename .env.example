# ── LLM API Keys ───────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Default Model ───────────────────────────────────
# Options: gemini, openai, anthropic, ollama
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash

# ── Ollama (local) ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Search ──────────────────────────────────────────
# Optional: SerpAPI key for more reliable Google search
SERPAPI_KEY=

# ── LinkedIn ────────────────────────────────────────
# Path to your LinkedIn session cookies file (JSON exported from browser)
LINKEDIN_COOKIES_FILE=data/linkedin_cookies.json

# ── Reference Data ──────────────────────────────────
PEGA_ACCOUNTS_FILE=data/pega_accounts.xlsx

# ── App Settings ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

GROQ_API_KEY=
HUGGINGFACE_API_KEY=
